---
import Base from '~/layouts/Base.astro';
import { SITE, SERVICES, CASE_STUDIES } from '~/data/site';

export function getStaticPaths() {
  return SERVICES.map(s => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const related = SERVICES.filter(s => s.slug !== service.slug).slice(0, 3);
const caseMatches = CASE_STUDIES.filter(cs => (cs.services || []).includes(service.slug)).slice(0, 3);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: service.title,
    provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
    description: service.short,
    areaServed: 'Worldwide',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE.url}/services/` },
      { '@type': 'ListItem', position: 3, name: service.title, item: `${SITE.url}/services/${service.slug}/` },
    ],
  },
];
---
<Base
  title={`${service.title} — ${service.tagline}`}
  description={service.short}
  structuredData={schema}
>
  <section class="relative overflow-hidden bg-ds-hero">
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="container-site relative py-20">
      <nav class="text-sm text-ink-400"><a href="/" class="hover:text-cyan-400">Home</a> / <a href="/services/" class="hover:text-cyan-400">Services</a> / <span class="text-white">{service.title}</span></nav>
      <div class="mt-8 max-w-3xl">
        <div class="flex items-center gap-3">
          <div class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-cyan-500/10 border border-cyan-500/30 text-3xl">{service.icon}</div>
          <span class="chip-cyan">{service.category}</span>
        </div>
        <h1 class="h1 mt-6">{service.title}</h1>
        <p class="lede mt-5">{service.tagline}</p>
      </div>
    </div>
  </section>

  <section class="section bg-navy-900">
    <div class="container-site">
      <div class="grid gap-14 lg:grid-cols-3">
        <div class="lg:col-span-2 space-y-12">
          <div>
            <h2 class="h3 text-white">Overview</h2>
            <p class="mt-4 text-lg text-ink-200 leading-relaxed">{service.short}</p>
          </div>

          <div>
            <h2 class="h3 text-white">Problems we solve</h2>
            <ul class="mt-5 space-y-3">
              {service.problems.map(p => (
                <li class="flex gap-3">
                  <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-red-500/15 text-red-400 text-xs font-bold">✗</span>
                  <span class="text-ink-200">{p}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="h3 text-white">What's included</h2>
            <ul class="mt-5 grid gap-3 sm:grid-cols-2">
              {service.includes.map(i => (
                <li class="flex gap-3">
                  <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-500/15 text-cyan-400 text-xs font-bold">✓</span>
                  <span class="text-ink-200">{i}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="h3 text-white">Tools we use</h2>
            <div class="mt-5 flex flex-wrap gap-2">
              {service.tools.map(t => <span class="chip">{t}</span>)}
            </div>
          </div>

          <div class="rounded-2xl bg-ds-cyan p-8 text-navy-900">
            <div class="text-xs font-bold uppercase tracking-widest">Deliverable</div>
            <p class="mt-3 text-xl font-display font-bold">{service.deliverable}</p>
          </div>

          {caseMatches.length > 0 && (
            <div>
              <h2 class="h3 text-white">Real results</h2>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {caseMatches.map(cs => (
                  <a href={`/case-studies/${cs.slug}/`} class="card group">
                    <span class="chip-cyan">{cs.industry}</span>
                    <h3 class="mt-3 font-semibold text-white">{cs.title}</h3>
                    <div class="mt-4 flex flex-wrap gap-3 text-sm">
                      {cs.metrics.slice(0, 2).map(m => (
                        <span><span class="grad-text font-bold">{m.v}</span> <span class="text-ink-400 text-xs">{m.k}</span></span>
                      ))}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-5">
            <div class="rounded-2xl bg-ds-gradient border border-cyan-500/30 p-6">
              <h3 class="text-lg font-semibold text-white">Ready to scale {service.title.toLowerCase()}?</h3>
              <p class="mt-3 text-sm text-ink-200">Free 30-min audit. We'll find the two biggest gaps in your current setup.</p>
              <a href={`/contact/?service=${encodeURIComponent(service.title)}&source=services/${service.slug}`} class="btn-primary w-full mt-5">Get a free audit</a>
              <a href={SITE.whatsapp} target="_blank" rel="noopener" class="btn-secondary w-full mt-3">WhatsApp us</a>
            </div>
            <div class="card">
              <h3 class="text-sm font-bold uppercase tracking-wider text-cyan-400">Related services</h3>
              <ul class="mt-4 space-y-2">
                {related.map(r => (<li><a class="text-sm text-ink-200 hover:text-cyan-400" href={`/services/${r.slug}/`}>{r.icon} {r.title}</a></li>))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
